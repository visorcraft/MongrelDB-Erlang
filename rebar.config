%% rebar3 build configuration for the MongrelDB Erlang client.
%%
%% A pure-Erlang HTTP client for MongrelDB - typed CRUD, a fluent query
%% builder, idempotent batch transactions, SQL, and schema introspection.
%% Built on the standard library (inets/httpc) with no external dependencies.

{erl_opts, [
    debug_info,
    {i, "src"},
    strict_iso_8601,
    nowarn_strict_iso_8601,
    warnings_as_errors
]}.

{deps, []}.

{project_plugins, [rebar3_ex_doc]}.

{shell, [
    {apps, [mongreldb]}
]}.

{dialyzer, [
    {warnings, [unknown]}
]}.

{ex_doc, [
    {source_url, <<"https://github.com/visorcraft/MongrelDB-Erlang">>},
    {extras, [<<"README.md">>, <<"docs/quickstart.md">>, <<"docs/queries.md">>,
              <<"docs/sql.md">>, <<"docs/transactions.md">>,
              <<"docs/errors.md">>, <<"docs/auth.md">>]},
    {main, <<"quickstart">>}
]}.

%% Hex publishing metadata.
{hex, [
    {doc, <<"ex_doc">>}
]}.
